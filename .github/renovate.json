{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>pl4nty/.github"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Process custom dependencies",
      "managerFilePatterns": [
        "/\\.ya?ml$/",
        "/\\.go$/",
        "/^PROJECT$/"
      ],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\n.*?\".*:(?<currentValue>.*)\""
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/Makefile/"
      ],
      "matchStrings": [
        "https://github.com/(?<packageName>.*)/releases/download/(?<currentValue>[^\\s]+)/[^\\s]+"
      ],
      "datasourceTemplate": "github-release-attachments"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "go"
      ],
      "matchPackageNames": [
        "/^k8s\\.io\\/api/",
        "/^k8s\\.io\\/apimachinery/",
        "/^k8s\\.io\\/client-go/"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "go",
        "github-release-attachments"
      ],
      "matchPackageNames": [
        "sigs.k8s.io/gateway-api",
        "kubernetes-sigs/gateway-api"
      ],
      "groupName": "Gateway API",
      "groupSlug": "kubernetes-sigs/gateway-api"
    }
  ]
}
